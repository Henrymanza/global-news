# ============================================================
# GEOINTEL PLATFORM — ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your API keys
# ============================================================

# ── ANTHROPIC (AI Analysis Engine) ──────────────────────────
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── NEWS APIs ────────────────────────────────────────────────
# NewsAPI.org — https://newsapi.org (free tier: 100 req/day)
VITE_NEWSAPI_KEY=your_newsapi_key_here

# GDELT Project — https://www.gdeltproject.org (FREE, no key needed)
# Used automatically for geopolitical event data

# ── MARKET DATA ──────────────────────────────────────────────
# Alpha Vantage — https://www.alphavantage.co (free tier: 25 req/day)
VITE_ALPHAVANTAGE_KEY=your_alphavantage_key_here

# Polygon.io — https://polygon.io (free tier: unlimited delayed data)
VITE_POLYGON_KEY=your_polygon_key_here

# ── FIREBASE (Push Notifications + Auth) ─────────────────────
# Create a Firebase project at https://console.firebase.google.com
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=123456789
VITE_FIREBASE_APP_ID=1:123456789:web:abcdef
VITE_FIREBASE_VAPID_KEY=your_vapid_key_here

# ── SUPABASE (Database + User Accounts) ──────────────────────
# Create a project at https://supabase.com (free tier available)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ── EMAIL ALERTS (Nodemailer / Gmail) ────────────────────────
# Use Gmail App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_gmail_app_password
EMAIL_FROM=GeoIntel Alerts <your_email@gmail.com>

# ── SMS ALERTS (Twilio) ──────────────────────────────────────
# Create account at https://twilio.com (free trial available)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# ── SERVER ───────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
