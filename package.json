{
  "name": "geointel-platform",
  "version": "1.0.0",
  "description": "Real-time geopolitical intelligence platform with market impact analysis",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev":         "vite",
    "dev:full":    "concurrently \"npm run server\" \"npm run dev\" --names \"server,frontend\" --prefix-colors \"cyan,green\"",
    "build":       "vite build",
    "preview":     "vite preview",
    "server":      "node server/index.js",
    "server:dev":  "node --watch server/index.js",
    "lint":        "eslint src --ext .js,.jsx --report-unused-disable-directives",
    "type-check":  "echo 'No TypeScript in this project'",
    "vercel-dev":  "vercel dev"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.39.0",
    "axios":                 "^1.6.0",
    "date-fns":              "^3.3.0",
    "firebase":              "^10.8.0",
    "leaflet":               "^1.9.4",
    "nodemailer":            "^6.9.9",
    "react":                 "^18.2.0",
    "react-dom":             "^18.2.0",
    "react-leaflet":         "^5.0.0",
    "react-router-dom":      "^6.22.0",
    "recharts":              "^2.12.0",
    "twilio":                "^4.22.0",
    "zustand":               "^4.5.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react":  "^4.2.0",
    "concurrently":          "^8.2.0",
    "cors":                  "^2.8.5",
    "dotenv":                "^16.4.0",
    "express":               "^4.18.0",
    "node-cron":             "^3.0.3",
    "vite":                  "^5.1.0"
  }
}
